APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=superligafm
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# --- Discord Configuration ---
# General webhook secret for signed webhook calls (Spatie)
DISCORD_WEBHOOK_SECRET=

# Rescission/offer notifications
DISCORD_WEBHOOK_URL=

# Transfer notifications
DISCORD_WEBHOOK_TRANSFERS=

# Auction notifications
DISCORD_WEBHOOK_AUCTIONS=

# Scheduled transferibles list
DISCORD_WEBHOOK_TRANSFERIBLES=

# Sanction cancellation notifications
DISCORD_WEBHOOK_SANCTIONS=

# AI Scout agent reports
DISCORD_AGENT_WEBHOOK=

# Fixture expiration alerts - default channel (fallback when no per-league webhook)
DISCORD_WEBHOOK_NOTIFICATIONS_URL=

# Fixture expiration alerts - per-league webhooks (optional, overrides default)
DISCORD_WEBHOOK_NOTIFICATIONS_PRIMERA=
DISCORD_WEBHOOK_NOTIFICATIONS_SEGUNDA=
DISCORD_WEBHOOK_NOTIFICATIONS_COPAFM=
DISCORD_WEBHOOK_NOTIFICATIONS_CHAMPIONS=
DISCORD_WEBHOOK_NOTIFICATIONS_EUROPA=

# Discord OAuth (for linking user accounts)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=
